style wechat_header is default
style wechat_body is default
style wechat_message_list is vbox
style wechat_header_title is wechat_text_base
style wechat_header_subtitle is wechat_text_base
style wechat_separator_frame is default
style wechat_separator_text is wechat_text_base
style wechat_timestamp_frame is default
style wechat_timestamp_text is wechat_text_base
style wechat_new_message_frame is default
style wechat_new_message_text is wechat_text_base
style wechat_sender_name is wechat_text_base
style wechat_sender_name_self is wechat_text_base
style wechat_bubble_other is default
style wechat_bubble_self is default
style wechat_bubble_text is wechat_text_base
style wechat_quote_chip is default
style wechat_quote_text is wechat_text_base


style wechat_header:
    background Solid("#ededed")
    xfill True
    left_padding 14
    right_padding 14
    top_padding 0
    bottom_padding 0


style wechat_body:
    background Solid("#ededed")
    xfill True
    yfill True
    left_padding 12
    right_padding 12
    top_padding 14
    bottom_padding 14


style wechat_message_list:
    spacing 18
    xfill True


style wechat_header_title:
    size 24
    color "#000000"
    xalign 0.5


style wechat_header_subtitle:
    size 15
    color "#8f8f8f"
    xalign 0.5


style wechat_separator_frame:
    background Solid("#d0d0d0")
    xpadding 12
    ypadding 6


style wechat_separator_text:
    size 17
    color "#666666"


style wechat_timestamp_frame:
    background None
    xpadding 0
    ypadding 0


style wechat_timestamp_text:
    size 15
    color "#7c7c7c"


style wechat_new_message_frame:
    background Solid("#d8e9ff")
    xpadding 14
    ypadding 7


style wechat_new_message_text:
    size 16
    color "#4970a8"


style wechat_sender_name:
    size 16
    color "#7b7b7b"


style wechat_sender_name_self:
    size 16
    color "#7b7b7b"
    xalign 1.0


style wechat_bubble_other:
    background Solid("#ffffff")
    xpadding 14
    ypadding 12


style wechat_bubble_self:
    background Solid("#95ec69")
    xpadding 14
    ypadding 12
    xalign 1.0


style wechat_bubble_text:
    size 18
    color "#1a1a1a"
    line_spacing 2


style wechat_quote_chip:
    background Solid("#d0d0d0")
    xpadding 10
    ypadding 6


style wechat_quote_text:
    size 15
    color "#666666"
