style wechat_home_header is default
style wechat_home_body is default
style wechat_home_title is wechat_text_base
style wechat_home_item_card is default
style wechat_home_item_title is wechat_text_base
style wechat_home_item_time is wechat_text_base
style wechat_home_item_preview is wechat_text_base
style wechat_home_unread_badge is default
style wechat_home_unread_text is wechat_text_base


style wechat_home_header:
    background Solid("#ececec")
    xfill True
    left_padding 12
    right_padding 12
    top_padding 0
    bottom_padding 0


style wechat_home_body:
    background Solid("#f7f7f7")
    xfill True
    yfill True
    xpadding 0
    ypadding 0


style wechat_home_title:
    size 26
    color "#1f1f1f"
    xalign 0.5
    yalign 0.5


style wechat_home_item_card:
    background Solid("#ffffff")
    xfill True
    left_padding 14
    right_padding 14
    top_padding 14
    bottom_padding 14


style wechat_home_item_title:
    size 22
    color "#161616"


style wechat_home_item_time:
    size 13
    color "#9a9a9a"
    xalign 1.0
    text_align 1.0


style wechat_home_item_preview:
    size 16
    color "#8c8c8c"
    xmaximum 300


style wechat_home_unread_badge:
    background Solid("#eb5545")
    xminimum 20
    yminimum 24
    xpadding 5
    ypadding 1


style wechat_home_unread_text:
    size 14
    color "#ffffff"
    xalign 0.5
    yalign 0.5
