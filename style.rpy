style wechat_device_outer is default
style wechat_device_bezel is default
style wechat_device_screen is default
style wechat_text_base is default
style wechat_toast_frame is default
style wechat_toast_text is wechat_text_base
style wechat_header_divider is default
style wechat_avatar is default
style wechat_avatar_text is wechat_text_base
style wechat_media_frame is default
style wechat_media_badge is wechat_text_base
style wechat_media_caption is wechat_text_base


style wechat_device_outer:
    background None
    xpadding 0
    ypadding 0


style wechat_device_bezel:
    background Solid("#0f0f10")
    xpadding 0
    ypadding 0


style wechat_device_screen:
    background Solid("#f2f2f2")
    xpadding 0
    ypadding 0


style wechat_text_base:
    font phone_font


style wechat_toast_frame:
    background Solid("#2a2a2a")
    xpadding 18
    ypadding 10


style wechat_toast_text:
    size 18
    color "#f7f7f7"


style wechat_header_divider:
    background Solid("#e5e5e5")
    xpadding 0
    ypadding 0
    ysize 1


style wechat_avatar:
    xpadding 0
    ypadding 0
    yalign 0.0


style wechat_avatar_text:
    xalign 0.5
    yalign 0.5
    size 24
    color "#ffffff"


style wechat_media_frame:
    background Solid("#d9d9d9")
    xminimum 180
    yminimum 180
    xpadding 12
    ypadding 12


style wechat_media_badge:
    size 22
    color "#555555"
    xalign 0.5


style wechat_media_caption:
    size 16
    color "#4b4b4b"
    xalign 0.5
